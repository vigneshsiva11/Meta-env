# ── Copy this to .env and fill in your values ──────────────────────────────
# DO NOT commit your actual keys to git.

# Gemini API key from https://aistudio.google.com/app/apikey
HF_TOKEN=your_gemini_api_key_here

# Gemini OpenAI-compatible endpoint (no changes needed)
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Gemini model to use
MODEL_NAME=gemini-2.0-flash

# Your local environment server URL (when running locally)
ENV_BASE_URL=http://localhost:8000

# Your Hugging Face Spaces URL (after deploying with: openenv push)
# ENV_BASE_URL=https://your-username-api-contract-env.hf.space
